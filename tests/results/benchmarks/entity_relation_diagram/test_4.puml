@startuml
' Use entity-style ER diagram for the SQLAlchemy schema

entity "Person" as Person {
  * id : int <<PK>>
  --
  * type : varchar(20)
  * first_name : varchar(50)
  * last_name : varchar(50)
  * created_at : datetime
}

entity "Student" as Student {
  * id : int <<PK, FK>>
  --
  * major : varchar(100)
  advisor_id : int <<FK>>
}

entity "Teacher" as Teacher {
  * id : int <<PK, FK>>
  --
  * department : varchar(100)
}

entity "Course" as Course {
  * id : int <<PK>>
  --
  * code : varchar(10) <<UQ>>
  * title : varchar(100)
  * teacher_id : int <<FK>>
}

entity "student_course" as StudentCourse {
  * student_id : int <<PK, FK>>
  * course_id : int <<PK, FK>>
}

Person ||--|| Student : "is a (joined-table inheritance)"
Person ||--|| Teacher : "is a (joined-table inheritance)"

Teacher ||--o{ Student : "advises (1..*)"
Teacher ||--o{ Course : "teaches (1..*)"

Student }o--o{ Course : "enrolled in"
(Student, Course) . StudentCourse

note right of StudentCourse
  Many-to-many association table
  linking Student and Course
end note
@enduml