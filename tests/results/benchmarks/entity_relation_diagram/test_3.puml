@startuml
entity person {
  *id : int <<PK>>
  --
  *type : varchar(20)
  *first_name : varchar(50)
  *last_name : varchar(50)
  *created_at : datetime
}

entity student {
  *id : int <<PK, FK>>
  --
  *major : varchar(100)
  advisor_id : int <<FK>>
}

entity teacher {
  *id : int <<PK, FK>>
  --
  *department : varchar(100)
}

entity course {
  *id : int <<PK>>
  --
  *code : varchar(10) <<unique>>
  *title : varchar(100)
  *teacher_id : int <<FK>>
}

entity student_course {
  *student_id : int <<PK, FK>>
  *course_id : int <<PK, FK>>
}

person ||--o{ student : "joined-table inheritance"
person ||--o{ teacher : "joined-table inheritance"
teacher ||--o{ student : "advises (1..*)"
teacher ||--o{ course : "teaches (1..*)"
student ||--o{ student_course : ""
course ||--o{ student_course : ""
@enduml