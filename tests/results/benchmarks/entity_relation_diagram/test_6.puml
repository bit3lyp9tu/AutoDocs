@startuml
!theme plain
hide circle
skinparam Linetype ortho

entity "Person" as person {
  * id : int <<PK>>
  --
  type : String(20)
  first_name : String(50)
  last_name : String(50)
  created_at : datetime
}

entity "Student" as student {
  * id : int <<PK>> <<FK>>
  --
  major : String(100)
  advisor_id : int <<FK>>
}

entity "Teacher" as teacher {
  * id : int <<PK>> <<FK>>
  --
  department : String(100)
}

entity "Course" as course {
  * id : int <<PK>>
  --
  code : String(10) <<unique>>
  title : String(100)
  teacher_id : int <<FK>>
}

entity "student_course" as student_course {
  * student_id : int <<PK>> <<FK>>
  * course_id : int <<PK>> <<FK>>
}

' Inheritance (Joined Table)
person ||--o| student : "is a"
person ||--o| teacher : "is a"

' Teacher as Advisor to Student
teacher ||--o{ student : "advises"

' Teacher teaches Courses
teacher ||--o{ course : "teaches"

' Many-to-Many via association table
student ||--o{ student_course
course ||--o{ student_course

@enduml