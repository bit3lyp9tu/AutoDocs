@startuml
class Base << (D,#FF7700) DeclarativeBase >>

class Person << (P,#AAAAAA) person >> {
    + id: int
    + type: str
    + first_name: str
    + last_name: str
    + created_at: datetime
}

class Student << (P,#AAAAAA) student >> {
    + id: int
    + major: str
    + advisor_id: int | None
    + advisor: Teacher | None
    + courses: List[Course]
}

class Teacher << (P,#AAAAAA) teacher >> {
    + id: int
    + department: str
    + students: List[Student]
    + courses: List[Course]
}

class Course << (P,#AAAAAA) course >> {
    + id: int
    + code: str
    + title: str
    + teacher_id: int
    + teacher: Teacher
    + students: List[Student]
}

class student_course << (T,#FFAAAA) Table >> {
    + student_id: int
    + course_id: int
}

Base <|-- Person
Base <|-- Course
Person <|-- Student
Person <|-- Teacher

Teacher "1" -- "0..*" Student : "advisor / students"
Teacher "1" -- "0..*" Course : "teacher / courses"
Student "0..*" -- "0..*" Course : "courses / students"

student_course .. Student : student_id
student_course .. Course : course_id

@enduml