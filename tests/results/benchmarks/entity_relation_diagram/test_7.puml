@startuml
' Entity Relationship Diagram for the SQLAlchemy models

' Entities
entity "person" {
  id : int (PK)
  type : string(20)
  first_name : string(50)
  last_name : string(50)
  created_at : datetime
}

entity "student" {
  id : int (PK, FK)
  major : string(100)
  advisor_id : int (FK)
}

entity "teacher" {
  id : int (PK, FK)
  department : string(100)
}

entity "course" {
  id : int (PK)
  code : string(10)
  title : string(100)
  teacher_id : int (FK)
}

entity "student_course" {
  student_id : int (PK, FK)
  course_id : int (PK, FK)
}

' Relationships
person ||--o{ student : "inherits"
person ||--o{ teacher : "inherits"
student ||--o{ student_course : "enrolled"
course ||--o{ student_course : "enrolled"
teacher ||--o{ course : "teaches"
student ||--o{ course : "enrolled"
course ||--o{ student : "enrolled"
teacher ||--o{ student : "advises"

' Constraints
student }o--|| teacher : "advisor"
@enduml