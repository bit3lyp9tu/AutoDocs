@startuml
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    ArrowColor Black
    BorderColor Black
}

class Animal {
    {static} kingdom: str = "Animalia"
    - name: str
    - age: int
    + Animal(name: str, age: int)
    + speak(): str
    + info(): str
}

class Dog {
    - breed: str
    + Dog(name: str, age: int, breed: str)
    + speak(): str
    + fetch(): str
}

class Cat {
    - indoor: bool = true
    + Cat(name: str, age: int, indoor: bool = true)
    + speak(): str
}

class GuideDog {
    - owner: str
    + GuideDog(name: str, age: int, breed: str, owner: str)
    + guide(): str
}

Dog --|> Animal
Cat --|> Animal
GuideDog --|> Dog
@enduml