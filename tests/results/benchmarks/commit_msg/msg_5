## 3.  Suggested clean‑up of `main.py`

Below is a **concise, runnable version** that incorporates the fixes above while keeping the original benchmark structure:

```python
#!/usr/bin/env python3
import sys
from time import sleep
from src.config_parser import YAMLConfig
from src.request import LLM_API

def main():
    model_list = [
        "meta-llama/Llama-3.3-70B-Instruct",
        "google/gemma-2-27b-it",
        "Qwen/Qwen2.5-72B-Instruct",
        "mistralai/Mixtral-8x7B-Instruct-v0.1",
        "01-ai/Yi-1.5-34B-Chat",
        "01-ai/Yi-1.5-9B-Chat",
        "microsoft/Phi-3-mini-128k-instruct",
        "google/gemma-2-9b-it",
        "meta-llama/Llama-3.2-1B-Instruct",
        "meta-llama/Llama-3.2-3B-Instruct",
        "zai-org/GLM-5.2-FP8",
    ]

    # ---------------------------------------------------------
    #   Benchmark configuration
    # ---------------------------------------------------------
    yaml = YAMLConfig('tests/configs/autodocs.yaml')
    source_path   = "tests/example_data/db_schema.py"   # <-- whatever you want to describe
    target_folder = "tests/results/benchmarks/commit_msg"

    # ---------------------------------------------------------
    #   Run each model
    # ---------------------------------------------------------
    for i, model_name in enumerate(model_list):
        print(f"\n=== Model [{i}] {model_name} ===")

        # 1️⃣  Load the system prompt (commit‑convention)
        with open(yaml.config.git.commit.sysprompt.file_path, "r", encoding="utf-8") as f:
            sys_prompt = "\n".join(f.readlines())

        # 2️⃣  Load the file that will be turned into a commit message
        with open(source_path, "r", encoding="utf-8") as f:
            user_prompt = f.read()

        # 3️⃣  Call the LLM
        api = LLM_API(config=yaml.config, model=model_name)
        try:
            raw_result = api.call(rule=sys_prompt, prompt=user_prompt)
        except ValueError as err:
            print(f"❌  LLM call failed: {err}")
            continue

        # 4️⃣  Persist the result so you can compare later
        out_path = f"{target_folder}/commit_{i}.txt"
        with open(out_path, "w", encoding="utf-8") as out_f:
            out_f.write(raw_result)

        print(f"✅  Saved commit message → {out_path}")

        # Respect the throttling delay defined in the config
        sleep(yaml.config.llm_service.api.request_delay_seconds)

if __name__ == "__main__":
    sys.exit(main())
```

*What changed?*

1. **Explicit loop variables** (`i, model_name`) – a bit clearer.
2. **Read both sys‑prompt and source file** before the LLM call.  
3. **Write the LLM output to a text file** (`commit_{i}.txt`).  
4. **Graceful error handling** – continue to the next model on failure.  
5. **Removed the commented‑out PlantUML code** (kept for reference, but not executed).  

If you still need the PlantUML benchmark somewhere else, extract it into a separate function (or script) rather than mixing the two concerns in the same loop.

